# Python / uv
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Environment / secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
*_rsa

# Local SQLite databases produced by the tool. The conventional
# location for these is the repo-local `cache/` directory; any
# `.sqlite` anywhere in the tree is also ignored as a safety net.
cache/
*.sqlite
*.sqlite3
*.db

# Output reports / sample analyses produced by the tool. These are
# run-specific artefacts (timestamped per snapshot), not source. Keep
# them locally for sharing — under `docs/examples/` is the convention
# — but do not version them.
docs/examples/

# Claude Code: project-shared instructions (.claude/skills, .claude/commands)
# ARE committed because they are part of the project's agent context.
# Local-only state is not.
.claude/settings.local.json
